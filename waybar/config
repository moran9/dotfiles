{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap",
        "hyprland/window"
    ],
    "modules-center": [
        "wlr/taskbar"
    ],
    "modules-right": [
        "custom/claude-usage",
        "network",
        "bluetooth",
        "pulseaudio",
        "custom/caffeine",
        "custom/mako",
        "clock",
        "tray",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{name}",
        "all-outputs": false,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 0
        }
    },
    "hyprland/submap": {
        "format": "яАб {}",
        "max-length": 24,
        "tooltip": false
    },
    "hyprland/window": {
        "format": "{title}",
        "max-length": 60,
        "separate-outputs": true,
        "rewrite": {
            "(.*) тАФ Mozilla Firefox": "$1 яЙй",
            "(.*) - Visual Studio Code": "$1 ґ░иЮ",
            "(.*) тАФ Dolphin": "$1 яБ╗"
        }
    },
    "custom/claude-usage": {
        "exec": "~/.config/waybar/scripts/claude_usage.py",
        "return-type": "json",
        "interval": 30,
        "tooltip": true
    },
    "network": {
        "format-wifi": "яЗл {essid}",
        "format-ethernet": "яГи {ipaddr}",
        "format-disconnected": "яДз off",
        "tooltip-format": "{ifname} via {gwaddr}\n{ipaddr}/{cidr}\nяБг {bandwidthDownBits}  яБв {bandwidthUpBits}",
        "on-click": "~/.config/hypr/scripts/wifi-popup.sh",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "яАж muted",
        "format-bluetooth": "{icon} {volume}% яКУ",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яАе",
            "headset": "яАе",
            "phone": "яВХ",
            "portable": "яДЛ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "scroll-step": 5,
        "on-click": "~/.config/hypr/scripts/audio-popup.sh",
        "on-click-right": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{desc}\nleft: mixer (per-app)\nright: pavucontrol\nmiddle: mute toggle"
    },
    "bluetooth": {
        "format": "яКУ {status}",
        "format-disabled": "яКУ off",
        "format-off": "яКУ off",
        "format-on": "яКУ on",
        "format-connected": "яКУ {device_alias}",
        "format-connected-battery": "яКУ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "~/.config/hypr/scripts/bluetooth-popup.sh",
        "on-click-right": "blueman-manager"
    },
    "custom/caffeine": {
        "exec": "~/.config/waybar/scripts/caffeine.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "~/.config/waybar/scripts/caffeine.sh toggle",
        "tooltip": true
    },
    "custom/mako": {
        "exec": "~/.config/waybar/scripts/mako_status.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/mako_status.sh toggle",
        "tooltip": true
    },
    "clock": {
        "format": "яАЧ {:%H:%M}",
        "format-alt": "яБ│ {:%a %d %b %Y}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
        "on-click": "switch-format"
    },
    "tray": {
        "spacing": 8,
        "icon-size": 16
    },
    "custom/power": {
        "format": "яАС",
        "tooltip": false,
        "on-click": "wlogout"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "spacing": 8,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "all-outputs": false,
        "ignore-list": [
            "waybar",
            "hypr-cheatsheet",
            "kitty_dropdown",
            "hypr-audio-popup",
            "hypr-bt-popup"
        ]
    }
}